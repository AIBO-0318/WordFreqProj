# crawler/.env 예시 파일
# 이 파일을 복사해서 같은 폴더에 ".env" 로 저장하고 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 등록되어 깃허브에 올라가지 않습니다.

# 왓챠피디아 로그인 (watcha_comment_crawler.py)
WATCHA_EMAIL=your_email@example.com
WATCHA_PASSWORD=your_password

# KOBIS(영화진흥위원회) OpenAPI 키 (boxoffice_crawler.py)
# 발급: https://www.kobis.or.kr/kobisopenapi
KOBIS_API_KEY=your_kobis_api_key
